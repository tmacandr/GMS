#include <windows.h>
#include "po_theme_test_resource.h"

IDR_PO_Theme_Test_Main_Menu MENU DISCARDABLE 
BEGIN

    POPUP "File"
    BEGIN
        MENUITEM "Save As..."                   ID_FILE_SAVE_AS
        MENUITEM "Set Font ..."                 ID_File_Set_Font
        MENUITEM SEPARATOR
        MENUITEM "Exit",                        ID_FILE_EXIT
    END

    POPUP "Ctrl"
    BEGIN
        MENUITEM "Zoom In",                     ID_ZOOM_IN
        MENUITEM "Zoom Out",                    ID_ZOOM_OUT
        MENUITEM "Zoom Ctrl ...",               ID_ZOOM_DIALOG
        MENUITEM SEPARATOR
        MENUITEM "Rotate North",                ID_ROTATE_NORTH
        MENUITEM "Rotate South",                ID_ROTATE_SOUTH
        MENUITEM "Rotate East",                 ID_ROTATE_EAST
        MENUITEM "Rotate West",                 ID_ROTATE_WEST
        MENUITEM SEPARATOR
        MENUITEM "Neutral Orientation",         ID_NEUTRAL_ORIENTATION
    END

    POPUP "LibRef"
    BEGIN
        MENUITEM "On/Off"                       ID_LibRef_On_Off
    END

    POPUP "Themes"
    BEGIN

       POPUP "Polit/Oceans"
       BEGIN
           MENUITEM "Text",                        ID_PO_Text
           MENUITEM "Edges/Boundaries"             ID_PO_Edges
           MENUITEM "Nodes",                       ID_PO_Nodes
       END

       POPUP "Drainage"
       BEGIN
           MENUITEM "Text",                        ID_DN_Text
           MENUITEM "Edges/Boundaries"             ID_DN_Edges
           MENUITEM "Nodes",                       ID_DN_Nodes
       END

       POPUP "Hypsography"
       BEGIN
           MENUITEM "Text",                        ID_HY_Text
           MENUITEM "Edges/Boundaries"             ID_HY_Edges
           MENUITEM "Nodes",                       ID_HY_Nodes
       END

       POPUP "Populated Places"
       BEGIN
           MENUITEM "Text",                        ID_PP_Text
           MENUITEM "Edges/Boundaries"             ID_PP_Edges
           MENUITEM "Nodes",                       ID_PP_Nodes
       END

       POPUP "Cultural Landmarks"
       BEGIN
           MENUITEM "Text",                        ID_CL_Text
           MENUITEM "Edges/Boundaries"             ID_CL_Edges
           MENUITEM "Nodes",                       ID_CL_Nodes
       END

       POPUP "Roads"
       BEGIN
           MENUITEM "Text",                        ID_RD_Text
           MENUITEM "Edges/Boundaries"             ID_RD_Edges
           MENUITEM "Nodes",                       ID_RD_Nodes
       END

       POPUP "Ocean Features"
       BEGIN
           MENUITEM "Text",                        ID_OF_Text
           MENUITEM "Edges/Boundaries"             ID_OF_Edges
           MENUITEM "Nodes",                       ID_OF_Nodes
       END
   END

END


IDD_ZOOM_CTRL_DIALOG DIALOG DISCARDABLE  0, 0, 129, 47
STYLE WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Zoom Control"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "OK",ID_OK_Zoom_Ctrl,7,26,50,14
    PUSHBUTTON      "Cancel",ID_CANCEL_Zoom_Ctrl,68,26,50,14
    LTEXT           "New Zoom Factor:",ID_Zoom_Ctrl_Label,7,7,67,13
    EDITTEXT        IDC_Zoom_Factor_Text,77,7,40,14,ES_AUTOHSCROLL | ES_NUMBER
END
