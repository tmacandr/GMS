//----------------------------------------------------------------------------
// File : tile_ref.rc
// Date : 21-Nov-99 : initial definition
//        10-Dec-99 : add separate button for Edge Bounding Rect
//
// Description:
//    User-interface objects (i.e. resources) defined in support of the
//    "tile_ref" application.
//----------------------------------------------------------------------------
#include <windows.h>
#include <tile_ref.h>

//#include "afxres.h"

IDR_Main_Menu MENU DISCARDABLE 
BEGIN
    POPUP "File"
    BEGIN
        MENUITEM "Save Map ..."                 ID_SAVE_MAP
        MENUITEM "Set Font ..."                 ID_Set_Font
        MENUITEM SEPARATOR
        MENUITEM "Exit",                        ID_FILE_EXIT
    END

    POPUP "Control"
    BEGIN
        MENUITEM "Zoom-In",                     ID_ZOOM_IN
        MENUITEM "Zoom-Out",                    ID_ZOOM_OUT
        MENUITEM "Zoom Ctrl ..."                ID_ZOOM_CONTROL
        MENUITEM SEPARATOR
        MENUITEM "Move North",                  ID_MOVE_NORTH
        MENUITEM "Move South",                  ID_MOVE_SOUTH
        MENUITEM "Move East",                   ID_MOVE_EAST
        MENUITEM "Move West",                   ID_MOVE_WEST
    END

    POPUP "LibRef"
    BEGIN
        MENUITEM "Browse",                      ID_Browse_Libref
        MENUITEM "Regional",                    ID_Regional_Libref
        MENUITEM "Edge Bounding Rect"           ID_Edge_Bounding_Rectangle
        MENUITEM "GEOREF Grid"                  ID_Georef_Grid
    END

    POPUP "TileRef"
    BEGIN
        MENUITEM "Edges",                       ID_Tile_Ref_Edges
    END

END


IDD_ZOOM_CTRL_DIALOG DIALOG DISCARDABLE  0, 0, 129, 47
STYLE WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Zoom Control"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "OK",ID_OK_Zoom_Ctrl,7,26,50,14
    PUSHBUTTON      "Cancel",ID_CANCEL_Zoom_Ctrl,68,26,50,14
    LTEXT           "New Zoom Factor:",ID_Zoom_Ctrl_Label,7,7,67,13
    EDITTEXT        IDC_Zoom_Factor_Text,77,7,40,14,ES_AUTOHSCROLL | ES_NUMBER
END

