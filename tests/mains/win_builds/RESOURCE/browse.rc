#include "windows.h"
#include "browse_resource.h"

IDR_Browse_Main_Menu MENU DISCARDABLE 
BEGIN
    POPUP "File"
    BEGIN
        MENUITEM "Save As...",                  ID_FILE_SAVE_AS
        MENUITEM "Set Font...",                 ID_File_Set_Font
        MENUITEM SEPARATOR
        MENUITEM "Exit",                        ID_FILE_EXIT
    END

    POPUP "Ctrl"
    BEGIN
        MENUITEM "Zoom In",                     ID_ZOOM_IN
        MENUITEM "Zoom Out",                    ID_ZOOM_OUT
        MENUITEM "Zoom Ctrl ...",               ID_ZOOM_DIALOG
        MENUITEM SEPARATOR
        MENUITEM "Rotate North",                ID_ROTATE_NORTH
        MENUITEM "Rotate South",                ID_ROTATE_SOUTH
        MENUITEM "Rotate East",                 ID_ROTATE_EAST
        MENUITEM "Rotate West",                 ID_ROTATE_WEST
        MENUITEM SEPARATOR
        MENUITEM "Neutral Orientation",         ID_NEUTRAL_ORIENTATION
    END

    POPUP "Themes"
    BEGIN
        MENUITEM "LibRef",                      ID_Lib_Ref
        MENUITEM "CO",                          ID_ONC_Compilation
        MENUITEM "DA",                          ID_Data_Availability
        MENUITEM "DN",                          ID_Drainage
        MENUITEM "DV",                          ID_Data_Volume
        MENUITEM "GR",                          ID_Geographic_Ref
        MENUITEM "IN",                          ID_ONC_Index
        MENUITEM "PO",                          ID_Political_Oceans
        MENUITEM "PP",                          ID_Populated_Places
    END

    POPUP "Tables"
    BEGIN
        MENUITEM "Database Header...",          ID_Database_Hdr_Tbl
        MENUITEM "Lib Attribute...",            ID_Lib_Attribute_Tbl
        MENUITEM SEPARATOR
        MENUITEM "Coverage Attrib...",          ID_Coverage_Attrib_Tbl
        MENUITEM "Data Quality...",             ID_Data_Quality_Tbl
        MENUITEM "Geographic Ref...",           ID_Geo_Ref_Tbl
        MENUITEM "Lib Header...",               ID_Lib_Header_Tbl
    END
END

//------------------------------------//
// Zoom Control Dialog
//------------------------------------//
IDD_ZOOM_CTRL_DIALOG DIALOG DISCARDABLE  0, 0, 129, 47
STYLE WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Zoom Control"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "OK",ID_OK_Zoom_Ctrl,7,26,50,14
    PUSHBUTTON      "Cancel",ID_CANCEL_Zoom_Ctrl,68,26,50,14
    LTEXT           "New Zoom Factor:",ID_Zoom_Ctrl_Label,7,7,67,13
    EDITTEXT        IDC_Zoom_Factor_Text,77,7,40,14,ES_AUTOHSCROLL | 
                    ES_NUMBER
END


//------------------------------------//
// Coverage Attribute Dialog
//------------------------------------//
IDD_CAT_DIALOG DIALOG DISCARDABLE  0, 0, 200, 200
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION
CAPTION "Coverage Attribute Table"
FONT 8, "Times New Roman"
BEGIN
    PUSHBUTTON      "Cancel",IDCANCEL,20,180,50,20
    EDITTEXT        IDC_CAT_Edit,5,5,180,165,ES_MULTILINE | ES_WANTRETURN | 
                    WS_VSCROLL | WS_HSCROLL
    PUSHBUTTON      "Save As...",IDC_CAT_Bitmap,105,180,50,20
END


