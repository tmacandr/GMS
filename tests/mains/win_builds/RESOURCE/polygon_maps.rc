#include <windows.h>
#include "polygon_maps_resource.h"

IDR_Polygon_Maps_Main_Menu MENU DISCARDABLE 
BEGIN
    POPUP "File"
    BEGIN
        MENUITEM "Save As..."                   ID_FILE_SAVE_AS
        MENUITEM SEPARATOR
        MENUITEM "Exit",                        ID_FILE_EXIT
    END

    POPUP "Ctrl"
    BEGIN
        MENUITEM "Zoom In",                     ID_ZOOM_IN
        MENUITEM "Zoom Out",                    ID_ZOOM_OUT
        MENUITEM "Zoom Ctrl ...",               ID_ZOOM_DIALOG
        MENUITEM SEPARATOR
        MENUITEM "Rotate North",                ID_ROTATE_NORTH
        MENUITEM "Rotate South",                ID_ROTATE_SOUTH
        MENUITEM "Rotate East",                 ID_ROTATE_EAST
        MENUITEM "Rotate West",                 ID_ROTATE_WEST
        MENUITEM SEPARATOR
        MENUITEM "Neutral Orientation",         ID_NEUTRAL_ORIENTATION

    END

    POPUP "Features"
    BEGIN
        MENUITEM "LibRef On/Off",               ID_LibRef_OnOff
        MENUITEM "Lat/Long Grid On/Off"         ID_LatLongGrid
        MENUITEM "Polygons of NG"               ID_Polygon_Map
        MENUITEM "Subtile Lines"                ID_Subtile_Lines
        MENUITEM "Lines of NG"                  ID_Lines_Of_NG
        MENUITEM "Subtile Polygons"             ID_Subtile_Polygons
    END

    POPUP "More"
    BEGIN
        MENUITEM "Drainage On/Off",             ID_DN_OnOff
        MENUITEM "HY Polygons On/Off"           ID_HY_OnOff
        MENUITEM "Populated Places On/Off"      ID_PP_OnOff
        MENUITEM "HY Lines On/Off"              ID_HY_Lines_OnOff
    END

END


IDD_ZOOM_CTRL_DIALOG DIALOG DISCARDABLE  0, 0, 129, 47
STYLE WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Zoom Control"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "OK",ID_OK_Zoom_Ctrl,7,26,50,14
    PUSHBUTTON      "Cancel",ID_CANCEL_Zoom_Ctrl,68,26,50,14
    LTEXT           "New Zoom Factor:",ID_Zoom_Ctrl_Label,7,7,67,13
    EDITTEXT        IDC_Zoom_Factor_Text,77,7,40,14,ES_AUTOHSCROLL | ES_NUMBER
END

